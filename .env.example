# Required environment variables for AI SkillVerse 2.0
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Your OpenRouter API key — get one free at https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# The public URL of your deployed site (used for OpenRouter's HTTP-Referer header)
# For local development, leave this as http://localhost:5173
SITE_URL=http://localhost:5173
